PORT=4000
NODE_ENV=development

# --- Supabase -----------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Backend only. Bypasses RLS. Never ship this to the mobile app.
SUPABASE_SERVICE_ROLE_KEY=

# --- KYC ----------------------------------------------------------------
# Private bucket. Must match storage.buckets.id in 20260717093000_users_kyc.sql.
KYC_BUCKET=kyc-documents
# Keep in sync with that bucket's file_size_limit (default 10 MB).
KYC_MAX_FILE_BYTES=10485760
# Lifetime of a minted signed URL, in seconds.
KYC_SIGNED_URL_TTL_SECONDS=300

# Where an invited user lands to set their password.
INVITE_REDIRECT_URL=

# --- MSG91 (phone OTP delivery) ----------------------------------------
# Used by the admin /auth/otp/test diagnostic. The login OTP itself is
# delivered by the send-sms Edge Function, which reads its own copy of these.
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=
# Name of the OTP variable in your MSG91 DLT/Flow template (default: otp).
MSG91_OTP_VAR=otp
MSG91_BASE_URL=https://control.msg91.com
