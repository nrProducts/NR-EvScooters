# ---------------------------------------------------------------------------
# Mock mode: run every screen with in-memory data, no backend, no Supabase.
# Leave this true until the API is deployed. In mock mode phone OTP is faked
# (any number; the code is 123456) and Google maps to the demo rider, so you
# can walk the whole auth flow with nothing configured.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_USE_MOCK=true

# ---------------------------------------------------------------------------
# Only needed when EXPO_PUBLIC_USE_MOCK=false.
# Only EXPO_PUBLIC_* is visible to the app. Never put the service-role key here.
# ---------------------------------------------------------------------------
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# The Express backend. Note: localhost from a phone means the PHONE, not your PC.
# Use your machine's LAN IP (the one Metro prints), or 10.0.2.2 for an Android emulator.
# EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1

# ---------------------------------------------------------------------------
# Auth notes (no client secrets needed here):
# - Phone OTP is native Supabase Auth; MSG91 is wired on the Supabase side via
#   the send-sms Edge Function, so the app needs no MSG91 keys.
# - Google Sign-In uses Supabase's browser OAuth flow. The redirect deep link
#   is  nrevscooters://auth-callback  (scheme from app.json). Add it to your
#   Supabase project's Auth → URL Configuration → Redirect URLs.
# ---------------------------------------------------------------------------
