# Local env for `supabase functions serve`. In hosted envs set these with
# `supabase secrets set --env-file ...` instead of committing them.

# Generated once; must match [auth.hook.send_sms].secret in config.toml.
# Create with:  openssl rand -base64 33  then prefix with  v1,whsec_
SEND_SMS_HOOK_SECRET=v1,whsec_REPLACE_ME

# MSG91 (see docs/auth/DEVELOPMENT.md and PRODUCTION.md)
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=
# Name of the OTP variable in your DLT/Flow template (default: otp)
MSG91_OTP_VAR=otp
MSG91_BASE_URL=https://control.msg91.com
